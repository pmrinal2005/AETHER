# ─────────────────────────────────────────────────────────────
# A.I.M. Environment Variables (copy to .env.local for dev, and
# add these in the Vercel Project → Settings → Environment Variables)
# ─────────────────────────────────────────────────────────────

# ── Supabase (Phase 1) ──
# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — NEVER expose to client. Used by backend API routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Upstash Redis (Phase 1 — revocation-bus pub/sub) ──
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── did:web hosting domain (Phase 2) ──
# The public domain the app is deployed at (used to build did:web identifiers
# and served at /.well-known/did.json). No trailing slash, no protocol needed
# in the DID but keep protocol here for building absolute URLs.
NEXT_PUBLIC_APP_DOMAIN=your-app.vercel.app

# ── Phase 3/4 (placeholders — not implemented in this build) ──
# MODAL_SCORE_ENDPOINT=
# MODAL_MODERATION_ENDPOINT=
# HUGGINGFACE_TOKEN=
